# Complex ELIN Test
# Testing recursion, nested expressions, and arrays

func int fib int n;
    if n <= 1;
        return n;
    end;
    return fib(n - 1) + fib(n - 2);
end;

func int sum_array arr int data int size;
    let int total = 0;
    let int i = 0;
    while i < size;
        total = total + data[i];
        i = i + 1;
    wend;
    return total;
end;

print "Fibonacci of 7:";
let int f7 = fib(7);
print f7;

print "Array Sum Test:";
let arr int my_nums = [10, 20, 30, 40, 50];
let int s = sum_array(my_nums, 5);
print s;

if f7 > 10;
    if s == 150;
        print "Logic works";
    end;
end;
