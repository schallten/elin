# Comprehensive ELIN test — all v0.3.0 + v0.4.0 features
# Tests: math, constants, strings, arrays, functions, conditionals,
#        loops, stack ops, I/O, string operations

# --- Constant folding (compile-time arithmetic) ---
let int cf_fold = (2 + 3) * (10 - 4) / 3;    # 5*6/3 = 10
let int cf_add = 42 + 15;                      # 57
let int cf_sub = 100 - 30;                     # 70
let int cf_mul = 7 * 6;                        # 42
let int cf_div = 81 / 9;                       # 9
let int cf_mod = 17 % 5;                       # 2
let int cf_neg = -42;                           # -42
let int cf_not = !0;                            # 1
let int cf_cmp = 10 > 5;                        # 1
print cf_fold;
print cf_add;
print cf_sub;
print cf_mul;
print cf_div;
print cf_mod;
print cf_neg;
print cf_not;
print cf_cmp;

# --- MOD (%) ---
let int a = 17;
let int b = 5;
let int r = a % b;
print r;

# --- ABS ---
let int neg = -42;
let int pos = abs(neg);
print pos;
print abs(-1);

# --- NEG (unary -) ---
let int x = 10;
let int y = -x;
print y;

# --- NOT (!) ---
let int z = 0;
if !z;
    print "nonzero";
else;
    print "zero";
end;

# --- INC (x = x + 1) ---
let int cnt = 0;
while cnt < 3;
    print cnt;
    cnt = cnt + 1;
wend;

# --- DEC (x = x - 1) ---
let int down = 3;
while down > 0;
    print down;
    down = down - 1;
wend;

# --- Functions ---
func int double int val;
    return val * 2;
end;
print double 21;

# --- Conditionals ---
let int score = 75;
if score >= 50;
    print "pass";
else;
    print "fail";
end;

# --- Arrays ---
let arr int data = [10, 20, 30];
print data;
let int first = data[0];
print first;
let int arr_len = len(data);
print arr_len;

# --- Stack operations ---
let int sv = 42;
sv = sv + 1;
print sv;
sv = sv - 1;
print sv;

# --- String operations ---
let str greeting = "hello";
let str name = "world";
let str msg = strcat(greeting, " ");
let str full = strcat(msg, name);
print full;

let int slen = strlen(full);
print slen;

let str part = substr(full, 0, 5);
print part;

let str other = substr(full, 6, 5);
print other;

let int cmp1 = strcmp("abc", "def");
print cmp1;

let int cmp2 = strcmp("xyz", "xyz");
print cmp2;

let int cmp3 = strcmp("zzz", "aaa");
print cmp3;

# --- write / flush ---
write "hello ";
write "world";
write "!";
flush;

# --- Nested string ops ---
let int nested_len = strlen(strcat("ab", "cd"));
print nested_len;

# --- All done ---
print "done";
